# -----------------------------------------------------------------------------
# Bazm-e-Sukhan .gitignore
# Web-based poetry platform: React frontend + Node.js/Express backend
# -----------------------------------------------------------------------------

# Dependency directories
# These are installed from package.json and should be regenerated locally.
node_modules/
**/node_modules/

# Environment and secret files
# Keep API keys, database credentials, and private config local only.
.env
.env.*
config.env

# Build and production output
# Ignore frontend and backend compiled artifact folders.
build/
dist/
.next/
coverage/

# Uploaded user content
# Do not commit user uploads or media files.
uploads/
media/
public/uploads/
public/media/

# Logs and temporary files
# Local runtime logs and temporary files should not be tracked.
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.tmp
*.temp

# IDE and editor settings
# Ignore local workspace/editor config files.
.vscode/
.idea/

# System files
# Operating system metadata should not be committed.
.DS_Store
Thumbs.db
desktop.ini

# Optional local files
# Include any custom local runtime files here.
*.env.local
.envrc
.python-version

# Ignore package manager lock files only if you do not wish to track them.
# Uncomment the appropriate line if needed.
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

